{
    "name": "amu/core",
    "description": "Core platform package for modular party and casino-style games.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Amu\\Core\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Amu\\Core\\CoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
