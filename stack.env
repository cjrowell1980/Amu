# Portainer Git stack environment file
# This file is loaded via compose `env_file:` for runtime variables inside containers.
# For Portainer Docker Standalone stacks, compose substitution values (for example APP_PORT)
# should be set in the Portainer stack Environment variables UI.

# ---------------------------
# Core app runtime
# ---------------------------
APP_ENV=production

# ---------------------------
# Database bootstrap values
# ---------------------------
DB_DATABASE=amu
DB_USERNAME=amu
# Leave blank for auto-generated passwords (handled by docker/mysql/entrypoint.sh).
# If your Portainer template does not allow blank, string "null" is also treated as blank.
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ---------------------------
# Optional cloudflared tunnel
# ---------------------------
# Leave blank to disable tunnel startup logic.
# String "null" is also treated as disabled by docker-compose command logic.
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_LOGLEVEL=info
