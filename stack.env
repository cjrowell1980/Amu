# Portainer Git stack environment file
# Loaded into containers via compose `env_file:`.
# For Docker Standalone compose substitution (APP_PORT, AMU_SUBNET, COMPOSE_PROFILES),
# set values in the Portainer stack Environment variables UI.

# ---------------------------
# Core app runtime
# ---------------------------
APP_ENV=production
# Set to a stable base64 key in production.
# If left blank, startup generates once and persists to amu_runtime_secrets volume.
APP_KEY=

# ---------------------------
# Database bootstrap values
# ---------------------------
DB_DATABASE=amu
DB_USERNAME=amu
# Leave blank for auto-generated passwords (handled by docker/mysql/entrypoint.sh).
# If your Portainer template does not allow blank, string "null" is also treated as blank.
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ---------------------------
# Optional cloudflared tunnel runtime values
# ---------------------------
# Leave blank to disable tunnel startup logic.
# String "null" is also treated as disabled.
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_LOGLEVEL=info

# Documentation/helper variable for your public hostname routing in Cloudflare.
# Token-managed tunnels still require hostname route configured in Cloudflare Zero Trust.
# In this containerized design, configure the Cloudflare hostname service target as:
#   http://nginx:80
# Do not use localhost unless the origin service is in the same cloudflared container.
CLOUDFLARED_PUBLIC_HOSTNAME=amonkeysuncle.co.uk
