# Portainer Git stack environment file
# This file is intended for Docker Compose variable substitution in Portainer.
# In Portainer stack settings, use this repository file as the env file.

# ---------------------------
# Host port mappings
# ---------------------------
# Change APP_PORT to move the website off port 8000 on the Docker host.
APP_PORT=8000
# MariaDB host port
DB_PORT=3306
# Redis host port
REDIS_PORT=6379
# Public Reverb/WebSocket host port
REVERB_PORT=8080
# Internal Reverb server port inside the container/network
REVERB_SERVER_PORT=8080

# ---------------------------
# Core app runtime
# ---------------------------
APP_ENV=production

# ---------------------------
# Database bootstrap values
# ---------------------------
DB_DATABASE=amu
DB_USERNAME=amu
# If blank is not allowed in Portainer template UIs, use "null" to trigger random generation.
DB_PASSWORD=null
DB_ROOT_PASSWORD=null

# ---------------------------
# Optional cloudflared tunnel
# ---------------------------
# Leave as "null" (or empty) to disable tunnel startup logic.
CLOUDFLARED_TUNNEL_TOKEN=null
CLOUDFLARED_LOGLEVEL=info
