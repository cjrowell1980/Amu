## Laravel application environment template (local/dev and app runtime).
## In Portainer Docker Standalone Git stacks:
## - `stack.env` is injected into services via compose `env_file:`
## - compose substitution values (for example APP_PORT/DB_PORT/REDIS_PORT/REVERB_PORT)
##   are set in Portainer's stack Environment variables UI

APP_NAME="Amu Game Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (MariaDB / MySQL) ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=amu
DB_USERNAME=amu
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ── Session / Cache ────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
CACHE_PREFIX=amu

# ── Queue ──────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Broadcasting (Reverb) ──────────────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=amu
REVERB_APP_KEY=amu-key
REVERB_APP_SECRET=amu-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Mail ───────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@amu.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── Admin Seeder ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password

# ── Telescope ──────────────────────────────────────────────────────────────────
TELESCOPE_ENABLED=true

# ── Cloudflared Tunnel (optional; enable compose profile "tunnel") ───────────
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_LOGLEVEL=info

# ── Optional External Network Overrides (ipvlan/vlan) ─────────────────────────
EXTERNAL_NETWORK_NAME=ipvlan-10
NGINX_STATIC_IP=
CLOUDFLARED_STATIC_IP=
